    {
      "ID": "MSG9",
      "FROMID": "LOGGER",
      "TOID": "EXTERNAL_OUT_1",
      "TEXT": "writeToFile()",
      "TYPE": "SEQ_LOST"
    },
    {
      "ID": "MSG10",
      "FROMID": "MONITOR",
      "TOID": "ALERT_MGR",
