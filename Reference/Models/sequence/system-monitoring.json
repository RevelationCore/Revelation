      "TEXT": "validateFormat()",
      "TYPE": "SEQ_SYNC_CALL"
    },
    {
      "ID": "MSG3",
      "FROMID": "MONITOR",
      "TOID": "MONITOR",
      "TEXT": "formatValid",
      "TYPE": "SEQ_RETURN"
    },
    {
      "ID": "FRG1",
      "TEXT": "retry on failure",
      "TYPE": "SEQ_FRG_LOOP"
    },
    {
      "ID": "MSG4",
      "FROMID": "MONITOR",
      "TOID": "VALIDATOR",
      "TEXT": "checkThresholds(data)",
      "TYPE": "SEQ_SYNC_CALL"
    },
    {
      "ID": "MSG5",
      "FROMID": "VALIDATOR",
      "TOID": "VALIDATOR",
      "TEXT": "calculateMetrics()",
      "TYPE": "SEQ_SYNC_CALL"
    },
    {
      "ID": "MSG6",
      "FROMID": "VALIDATOR",
      "TOID": "VALIDATOR",
      "TEXT": "metrics",
      "TYPE": "SEQ_RETURN"
    },
    {
      "ID": "MSG7",
      "FROMID": "VALIDATOR",
      "TOID": "MONITOR",
