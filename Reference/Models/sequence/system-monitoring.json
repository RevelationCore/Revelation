    },
    {
      "ID": "VALIDATOR",
      "TEXT": "Validator",
      "TYPE": "SEQ_CONTROL"
    },
    {
      "ID": "LOGGER",
      "TEXT": "Logger",
      "TYPE": "SEQ_COMPONENT"
    },
    {
      "ID": "ALERT_MGR",
      "TEXT": "Alert Manager",
      "TYPE": "SEQ_CONTROL"
    }
